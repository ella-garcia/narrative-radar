# Narrative Radar — environment variables.
#
# All keys are OPTIONAL. The app runs end-to-end without any of them via
# deterministic fallback paths (mock claim extraction, template-only briefings,
# hash-TF-IDF embeddings). Set the keys to upgrade each stage to its real
# implementation.
#
# To use:  cp .env.example .env  &&  edit .env

# --- LLM providers --------------------------------------------------------
# OpenAI — used by the GPT-4o claim extractor (backend/claims/gpt4o_extractor.py)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — used by the Claude briefing summary (backend/briefing/claude_brief.py)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional metadata enrichment ----------------------------------------
# Hive Moderation — third-party synthetic-media likelihood signal.
# Used as METADATA ONLY in the per-video drawer; never gates a compliance gap.
# https://hivemoderation.com/
# Legacy/project-token mode:
HIVE_API_KEY=
# Access ID + Secret Key mode:
HIVE_ACCESS_ID=
HIVE_SECRET_KEY=
HIVE_API_BASE_URL=https://api.thehive.ai/api/v3/task/sync
# If Hive gives different header names for your project, override these.
HIVE_ACCESS_ID_HEADER=X-Hive-Access-ID
HIVE_SECRET_KEY_HEADER=Authorization
HIVE_SECRET_KEY_SCHEME=Bearer
